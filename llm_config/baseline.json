{
    "openai-gpt-5-nano": {
        "comment": "This is slow. It's paid, and requires that you have a OPENAI_API_KEY in the .env file. This is a reasoning model, so it takes MUCH longer to create a plan. $0.05/M input tokens. $0.40/M output tokens.",
        "luigi_workers": 4,
        "class": "OpenAI",
        "arguments": {
            "model": "gpt-5-nano",
            "api_key": "${OPENAI_API_KEY}",
            "temperature": 1.0,
            "timeout": 120.0,
            "context_window": 400000,
            "is_function_calling_model": false,
            "is_chat_model": true,
            "max_tokens": 128000,
            "max_retries": 5
        },
        "pricing": {
            "input_per_million_tokens": 0.05,
            "output_per_million_tokens": 0.40
        },
        "pricing_kind": "paid"
    },
